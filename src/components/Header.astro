---
import { translations, langs, type Lang } from "../i18n/index";
import { Menu } from "lucide-astro";
import logo from "../assets/merkan-logo.svg";

interface Props {
  lang: Lang;
  currentPath: string;
  t: (typeof translations)["en"];
}

const { lang, currentPath, t } = Astro.props;

const navItems = [
  { href: `/${lang}/about`, label: t.nav.about },
  { href: `/${lang}/services`, label: t.nav.services },
  { href: `/${lang}/how-we-work`, label: t.nav.howWeWork },
  { href: `/${lang}/contact`, label: t.nav.contact },
];

function switchLangUrl(targetLang: string, path: string) {
  return path.replace(\/^\/[a-z]{2}\//, `\/${targetLang}/`);
}

const orderedLangs: Lang[] = ["en", "tr", "fa"];
---

<header class="sticky top-0 z-50 glass border-b border-white/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href={`/${lang}/`} class="flex items-center gap-3 shrink-0">
        <img
          src={logo.src}
          alt="Merkan"
          class="h-10 w-auto"
          width="40"
          height="40"
        />
        <span class="text-2xl font-bold text-navy-900 tracking-tight"
          >Merkan</span
        >
      </a>

      <nav class="hidden lg:flex items-center gap-6 xl:gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-slate-600 hover:text-navy-800 transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-3">
        <div class="hidden lg:flex items-center gap-1 text-sm">
          {
            orderedLangs.map((l) => (
              <a
                href={switchLangUrl(l, currentPath)}
                class={`px-3 py-1.5 rounded-full transition-all ${l === lang ? "bg-navy-900 text-white font-medium" : "text-slate-500 hover:text-navy-800 hover:bg-navy-50"}`}
              >
                {translations[l].langLabel}
              </a>
            ))
          }
        </div>

        <label
          for="menu-toggle"
          class="lg:hidden p-2 text-slate-600 cursor-pointer"
        >
          <Menu class="w-6 h-6" />
        </label>
      </div>
    </div>
  </div>

  <input type="checkbox" id="menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block lg:hidden border-t bg-white/95">
    <nav class="flex flex-col p-4 gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="px-4 py-3 text-base font-medium text-slate-700 hover:bg-navy-50 rounded-lg transition-colors"
          >
            {item.label}
          </a>
        ))
      }
      <div class="flex gap-2 pt-3 border-t mt-2">
        {
          orderedLangs.map((l) => (
            <a
              href={switchLangUrl(l, currentPath)}
              class={`flex-1 text-center px-3 py-2.5 rounded-lg text-sm ${l === lang ? "bg-navy-900 text-white" : "bg-slate-100 text-slate-600"}`}
            >
              {translations[l].langLabel}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</header>
