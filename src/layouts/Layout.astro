---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { translations, isLang, defaultLang, type Lang } from "../i18n/index";
import favicon from "../assets/favicon.svg";

interface Props {
  lang?: Lang;
}

let { lang = defaultLang } = Astro.props;
if (!isLang(lang)) lang = defaultLang;

const t = translations[lang];
const dir = lang === "fa" ? "rtl" : "ltr";
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Vazirmatn:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
  </head>
  <body
    class="min-h-screen flex flex-col bg-stone-50 text-slate-800 antialiased"
  >
    <Header lang={lang} currentPath={currentPath} t={t} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer t={t} />
  </body>
</html>
