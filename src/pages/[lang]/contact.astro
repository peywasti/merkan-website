---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "fa" } },
    { params: { lang: "tr" } },
  ];
}
import { translations, isLang, defaultLang, type Lang } from "../../i18n/index";
import { Mail, Phone, Send, MapPin } from "lucide-astro";

const { lang } = Astro.params;
let safeLang: Lang = defaultLang;
if (isLang(lang)) safeLang = lang;
const t = translations[safeLang];
---

<Layout lang={safeLang}>
  <!-- Hero -->
  <section class="bg-navy-900 text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">{t.contact.title}</h1>
      <p class="text-lg text-navy-200 max-w-3xl leading-relaxed">
        {t.contact.desc}
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label
                  for="name"
                  class="block text-sm font-medium text-slate-700 mb-2"
                >
                  {t.contact.form.name}
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-stone-200 bg-stone-50 focus:bg-white focus:border-gold-500 focus:ring-2 focus:ring-gold-200 outline-none transition-all"
                />
              </div>
              <div>
                <label
                  for="company"
                  class="block text-sm font-medium text-slate-700 mb-2"
                >
                  {t.contact.form.company}
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 rounded-xl border border-stone-200 bg-stone-50 focus:bg-white focus:border-gold-500 focus:ring-2 focus:ring-gold-200 outline-none transition-all"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label
                  for="email"
                  class="block text-sm font-medium text-slate-700 mb-2"
                >
                  {t.contact.form.email}
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  dir="ltr"
                  class="w-full px-4 py-3 rounded-xl border border-stone-200 bg-stone-50 focus:bg-white focus:border-gold-500 focus:ring-2 focus:ring-gold-200 outline-none transition-all"
                />
              </div>
              <div>
                <label
                  for="phone"
                  class="block text-sm font-medium text-slate-700 mb-2"
                >
                  {t.contact.form.phone}
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  dir="ltr"
                  class="w-full px-4 py-3 rounded-xl border border-stone-200 bg-stone-50 focus:bg-white focus:border-gold-500 focus:ring-2 focus:ring-gold-200 outline-none transition-all"
                />
              </div>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                {t.contact.form.message}
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-xl border border-stone-200 bg-stone-50 focus:bg-white focus:border-gold-500 focus:ring-2 focus:ring-gold-200 outline-none transition-all resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 bg-navy-900 hover:bg-navy-800 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:scale-105"
            >
              <Send class="w-5 h-5" />
              {t.contact.form.submit}
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6">
          <h2 class="text-xl font-bold text-navy-900 mb-6">
            {t.contact.info.title}
          </h2>

          <div
            class="p-6 rounded-2xl bg-stone-50 border border-stone-100 flex items-start gap-4"
          >
            <div
              class="w-12 h-12 rounded-xl bg-gold-100 text-gold-700 flex items-center justify-center shrink-0"
            >
              <Mail class="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 mb-1">
                {t.contact.info.email}
              </h3>
              <p class="text-slate-600 text-sm" dir="ltr">info@merkan.ir</p>
            </div>
          </div>

          <div
            class="p-6 rounded-2xl bg-stone-50 border border-stone-100 flex items-start gap-4"
          >
            <div
              class="w-12 h-12 rounded-xl bg-gold-100 text-gold-700 flex items-center justify-center shrink-0"
            >
              <MapPin class="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 mb-1">
                {t.contact.addresses.turkey.label}
              </h3>
              <p class="text-slate-600 text-sm">
                {t.contact.addresses.turkey.address}
              </p>
              <div class="flex items-center gap-2 mt-2 text-slate-600 text-sm">
                <Phone class="w-4 h-4" />
                <span dir="ltr">+90 539 771 3059</span>
              </div>
            </div>
          </div>

          <div
            class="p-6 rounded-2xl bg-stone-50 border border-stone-100 flex items-start gap-4"
          >
            <div
              class="w-12 h-12 rounded-xl bg-gold-100 text-gold-700 flex items-center justify-center shrink-0"
            >
              <MapPin class="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 mb-1">
                {t.contact.addresses.iran.label}
              </h3>
              <p class="text-slate-600 text-sm">
                {t.contact.addresses.iran.address}
              </p>
              <div class="flex items-center gap-2 mt-2 text-slate-600 text-sm">
                <Phone class="w-4 h-4" />
                <span dir="ltr">+98 914 309 4064</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
