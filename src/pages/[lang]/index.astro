---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "fa" } },
    { params: { lang: "tr" } },
  ];
}
import { translations, isLang, defaultLang, type Lang } from "../../i18n/index";
import { ArrowRight } from "lucide-astro";

const { lang } = Astro.params;
let safeLang: Lang = defaultLang;
if (isLang(lang)) safeLang = lang;
const t = translations[safeLang];
---

<Layout lang={safeLang}>
  <!-- Hero -->
  <section
    class="text-white py-24 lg:py-32 relative overflow-hidden bg-cover bg-center bg-no-repeat"
    style="background-image: url('/hero-abstract.svg');"
  >
    <div class="absolute inset-0 bg-primary-950/30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="max-w-3xl animate-fade-in">
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 tracking-tight"
        >
          {t.home.title}
        </h1>
        <p class="text-xl md:text-2xl text-accent-300 mb-8 font-light">
          {t.home.subtitle}
        </p>
        <p class="text-lg text-primary-200 mb-10 max-w-2xl leading-relaxed">
          {t.home.desc}
        </p>
        <a
          href={`/${safeLang}/contact`}
          class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-400 text-primary-900 font-semibold px-8 py-4 rounded-xl transition-all hover:scale-105 shadow-lg shadow-accent-500/25"
        >
          {t.home.cta}
          <ArrowRight class="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Key Points -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          t.home.points.map((point, i) => (
            <div class="p-6 rounded-2xl bg-stone-50 border border-stone-100 card-hover">
              <div class="w-10 h-10 rounded-lg bg-primary-900 text-accent-400 flex items-center justify-center mb-4 text-lg font-bold">
                {i + 1}
              </div>
              <p class="text-slate-700 font-medium leading-relaxed">{point}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-primary-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        {
          safeLang === "fa"
            ? "آماده ورود به بازار ایران هستید؟"
            : safeLang === "tr"
              ? "İran Pazarına Girmeye Hazır mısınız?"
              : "Ready to Enter the Iranian Market?"
        }
      </h2>
      <p class="text-primary-200 mb-8">
        {
          safeLang === "fa"
            ? "با تیمی با بیش از ۲۵ سال تجربه و شناخت عمیق از بازار همراه شوید."
            : safeLang === "tr"
              ? "25+ yıllık deneyimi ve derin pazar bilgisiyle bir ekiple çalışın."
              : "Partner with a team that brings 25+ years of experience and deep market knowledge."
        }
      </p>
      <a
        href={`/${safeLang}/contact`}
        class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-400 text-primary-900 font-semibold px-8 py-4 rounded-xl transition-all hover:scale-105"
      >
        {
          safeLang === "fa"
            ? "شروع کنید"
            : safeLang === "tr"
              ? "Hemen Başlayın"
              : "Get Started Today"
        }
      </a>
    </div>
  </section>
</Layout>
