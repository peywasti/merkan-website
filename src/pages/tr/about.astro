---
import Layout from "../../layouts/Layout.astro";

import { translations, type Lang } from "../../i18n/index";
import {
  Target,
  Briefcase,
  Scale,
  Truck,
  Award,
  CheckCircle,
} from "lucide-astro";

const lang: Lang = "tr";
const safeLang: Lang = "tr";
// Turkish locale
const t = translations[safeLang];

const offerIcons = [Briefcase, Scale, Truck, Award];
---

<Layout lang={safeLang}>
  <!-- Hero -->
  <section class="bg-primary-900 text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">{t.about.title}</h1>
      <p class="text-lg text-primary-200 max-w-3xl leading-relaxed">
        {t.about.desc}
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <div
          class="w-14 h-14 rounded-full bg-accent-100 text-accent-600 flex items-center justify-center mx-auto mb-6"
        >
          <Target class="w-7 h-7" />
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary-900 mb-4">
          {t.about.missionTitle}
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          {t.about.missionDesc}
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold text-primary-900 text-center mb-10"
      >
        {t.about.offerTitle}
      </h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {
          t.about.offers.map((offer, i) => {
            const Icon = offerIcons[i] || CheckCircle;
            return (
              <div class="p-6 rounded-2xl bg-stone-50 border border-stone-100 card-hover flex gap-4">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-primary-900 text-accent-400 flex items-center justify-center">
                  <Icon class="w-6 h-6" />
                </div>
                <div>
                  <h3 class="font-bold text-slate-800 mb-1">{offer.title}</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    {offer.desc}
                  </p>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Closing -->
  <section class="py-16 bg-stone-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-slate-700 leading-relaxed">{t.about.closing}</p>
    </div>
  </section>
</Layout>
